# MCP konektor pro nominal-cmms — běh na Google Cloud Run.
FROM node:20-slim AS build
WORKDIR /app
COPY package*.json ./
RUN npm install
COPY tsconfig.json ./
COPY src ./src
RUN npm run build

FROM node:20-slim
WORKDIR /app
ENV NODE_ENV=production
COPY package*.json ./
RUN npm install --omit=dev
COPY --from=build /app/dist ./dist
# Cloud Run nastaví PORT; server na něm naslouchá.
EXPOSE 8080
CMD ["node", "dist/index.js"]
