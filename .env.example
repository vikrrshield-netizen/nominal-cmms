# .env.local
# NOMINAL CMMS — Environment Variables
# Zkopíruj tento soubor jako .env.local a doplň hodnoty

# ═══════════════════════════════════════════════════════════════════
# FIREBASE CONFIG
# Hodnoty najdeš v Firebase Console > Project Settings > Your Apps
# ═══════════════════════════════════════════════════════════════════

VITE_FIREBASE_API_KEY=AIzaSy...
VITE_FIREBASE_AUTH_DOMAIN=nominal-cmms.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=nominal-cmms
VITE_FIREBASE_STORAGE_BUCKET=nominal-cmms.appspot.com
VITE_FIREBASE_MESSAGING_SENDER_ID=123456789012
VITE_FIREBASE_APP_ID=1:123456789012:web:abc123def456

# ═══════════════════════════════════════════════════════════════════
# EMULATORS (lokální vývoj)
# ═══════════════════════════════════════════════════════════════════

# Nastav na 'true' pro použití lokálních emulátorů
VITE_USE_EMULATORS=false

# ═══════════════════════════════════════════════════════════════════
# APP CONFIG
# ═══════════════════════════════════════════════════════════════════

VITE_APP_NAME=NOMINAL CMMS
VITE_APP_VERSION=1.0.0
