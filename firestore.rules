rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•
    // HELPER FUNCTIONS
    // â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•

    // Authenticated user
    function isAuth() {
      return request.auth != null;
    }

    // Get user document from Firestore
    function getUserDoc() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data;
    }

    // Get user role
    function userRole() {
      return getUserDoc().role;
    }

    // Role checks
    function isSuperAdmin() {
      return isAuth() && userRole() == 'SUPERADMIN';
    }

    function isMajitel() {
      return isAuth() && userRole() == 'MAJITEL';
    }

    function isVedeni() {
      return isAuth() && userRole() == 'VEDENI';
    }

    function isVyroba() {
      return isAuth() && userRole() == 'VYROBA';
    }

    function isUdrzba() {
      return isAuth() && userRole() == 'UDRZBA';
    }

    function isOperator() {
      return isAuth() && userRole() == 'OPERATOR';
    }

    // Role groups
    function isAdmin() {
      return isSuperAdmin() || isMajitel();
    }

    function isManagement() {
      return isAdmin() || isVedeni();
    }

    function isTechnician() {
      return isUdrzba() || isVyroba();
    }

    function isAnyRole() {
      return isAuth() && userRole() in ['SUPERADMIN', 'MAJITEL', 'VEDENI', 'VYROBA', 'UDRZBA', 'SKLADNIK', 'OPERATOR'];
    }

    // Soft delete check â€” update MUST only set isDeleted=true, not actually delete
    function isSoftDelete() {
      return request.resource.data.isDeleted == true
        && request.resource.data.diff(resource.data).affectedKeys().hasOnly([
          'isDeleted',
          'deletedAt',
          'deletedBy',
          'updatedAt'
        ])
        && resource.data.isDeleted != true;
    }

    function isSafeOwnUserUpdate(userId) {
      return request.auth.uid == userId
        && request.resource.data.diff(resource.data).affectedKeys().hasOnly([
          'displayName',
          'phone',
          'color',
          'nickname',
          'workwear',
          'workwearSizes',
          'updatedAt',
          'updatedBy'
        ]);
    }

    function isSafeManagedUserUpdate() {
      return isManagement()
        && request.resource.data.diff(resource.data).affectedKeys().hasOnly([
          'displayName',
          'phone',
          'email',
          'color',
          'buildingId',
          'plantId',
          'active',
          'isActive',
          'pinLength',
          'nickname',
          'workwear',
          'workwearSizes',
          'updatedAt',
          'updatedBy'
        ]);
    }

    function isTaskStartOnlyUpdate() {
      return request.resource.data.diff(resource.data).affectedKeys().hasOnly([
          'status',
          'startedAt',
          'updatedAt'
        ])
        && !(resource.data.status in ['completed', 'cancelled'])
        && request.resource.data.status == 'in_progress'
        && request.resource.data.startedAt is timestamp;
    }

    function isClientAuditLogCreate() {
      return request.resource.data.userId == request.auth.uid
        && request.resource.data.action is string
        && (
          request.resource.data.documentId is string
          || request.resource.data.category == 'app_error'
        )
        && (
          request.resource.data.createdAt is timestamp
          || request.resource.data.timestamp is timestamp
        );
    }

    function canCreateNotification() {
      return hasPermission('admin.manage')
        || hasPermission('wo.create')
        || hasPermission('wo.update')
        || hasPermission('asset.update')
        || hasPermission('inv.manage')
        || hasPermission('inv.restock')
        || hasPermission('datalogger.temperature.write')
        || hasPermission('datalogger.manage')
        || hasPermission('production.manage')
        || hasPermission('schedule.manage');
    }

    function isValidNotificationCreate() {
      return canCreateNotification()
        && request.resource.data.createdAt is timestamp
        && request.resource.data.type is string
        // Účtovatelnost: každá notifikace musí nést PRAVÉHO odesílatele (nelze podvrhnout cizí identitu).
        && request.resource.data.createdBy == request.auth.uid
        && (
          (request.resource.data.userId is string)
          || (
            request.resource.data.targetType in ['role', 'user', 'all']
            && request.resource.data.targetId is string
          )
        );
    }

    // Verify updatedAt timestamp is present on writes
    function hasTimestamp() {
      return request.resource.data.updatedAt is timestamp;
    }

    // Legacy + custom permission check.
    // This mirrors the app roles enough for database protection.
    function hasCustomGrant(permission) {
      return isAuth()
        && ('customPermissions' in getUserDoc())
        && ('granted' in getUserDoc().customPermissions)
        && permission in getUserDoc().customPermissions.granted;
    }

    function hasCustomRevoke(permission) {
      return isAuth()
        && ('customPermissions' in getUserDoc())
        && ('revoked' in getUserDoc().customPermissions)
        && permission in getUserDoc().customPermissions.revoked;
    }

    function hasRolePermission(permission) {
      return (
        userRole() == 'MAJITEL'
        && permission in [
          'wo.read',
          'asset.read',
          'fleet.read',
          'datalogger.read',
          'user.read',
          'report.read', 'report.export', 'audit.read',
          'finance.view', 'secretbox.view', 'purchase.approve',
          'ai.use', 'admin.view',
          'warehouse.view', 'shifts.view'
        ]
      ) || (
        userRole() == 'VEDENI'
        && permission in [
          'wo.read', 'wo.approve',
          'asset.read',
          'fleet.manage', 'fleet.read',
          'datalogger.read',
          'user.manage', 'user.read',
          'report.read', 'report.export', 'audit.read',
          'finance.view', 'purchase.approve',
          'weekly.modify', 'ai.use', 'admin.view',
          'warehouse.view', 'warehouse.manage', 'shifts.view', 'shifts.manage'
        ]
      ) || (
        userRole() == 'SUPERADMIN'
        && permission in [
          'wo.create', 'wo.update', 'wo.delete', 'wo.read', 'wo.approve', 'wo.close', 'wo.plan', 'wo.assign',
          'asset.create', 'asset.update', 'asset.delete', 'asset.read',
          'inv.consume', 'inv.restock', 'inv.manage', 'inv.order',
          'datalogger.read', 'datalogger.temperature.write', 'datalogger.manage',
          'fleet.manage', 'fleet.read',
          'user.manage', 'user.read',
          'zone.change',
          'report.read', 'report.export', 'audit.read',
          'weekly.modify', 'ai.use', 'schedule.manage', 'production.manage',
          'admin.view', 'admin.manage',
          'warehouse.view', 'warehouse.manage', 'shifts.view', 'shifts.manage'
        ]
      ) || (
        userRole() == 'UDRZBA'
        && permission in [
          'wo.create', 'wo.update', 'wo.read', 'wo.close',
          'asset.read', 'asset.update',
          'inv.consume', 'inv.restock',
          'datalogger.read', 'datalogger.temperature.write', 'datalogger.manage',
          'fleet.read',
          'report.read',
          'ai.use', 'schedule.manage', 'production.manage',
          'warehouse.view', 'warehouse.manage', 'shifts.view', 'shifts.manage'
        ]
      ) || (
        userRole() == 'VYROBA'
        && permission in [
          'wo.create', 'wo.read', 'wo.approve', 'wo.plan',
          'asset.read',
          'zone.change',
          'weekly.modify', 'report.read',
          'production.manage', 'warehouse.view', 'warehouse.manage', 'shifts.view', 'shifts.manage'
        ]
      ) || (
        userRole() == 'SKLADNIK'
        && permission in [
          'wo.create', 'wo.update', 'wo.read',
          'asset.read',
          'inv.consume', 'inv.restock', 'inv.manage', 'inv.order',
          'datalogger.read', 'datalogger.temperature.write',
          'report.read', 'schedule.manage'
        ]
      ) || (
        userRole() == 'OPERATOR'
        && permission in [
          'wo.create',
          'wo.read',
          'asset.read',
          'production.read'
        ]
      );
    }

    function hasPermission(permission) {
      return isAuth()
        && !hasCustomRevoke(permission)
        && (hasRolePermission(permission) || hasCustomGrant(permission));
    }

    function canReadInventory() {
      return hasPermission('inv.consume')
        || hasPermission('inv.restock')
        || hasPermission('inv.manage')
        || hasPermission('inv.order');
    }

    function canWriteInspection() {
      return hasPermission('weekly.modify')
        || hasPermission('asset.update')
        || hasPermission('wo.update');
    }

    function canWriteGearboxTemperature() {
      return hasPermission('asset.update')
        || hasPermission('wo.update')
        || hasPermission('wo.create')
        || hasPermission('gearbox.temperature.write')
        || isOperator();
    }

    function isGearboxTemperatureAssetUpdate() {
      return request.resource.data.diff(resource.data).affectedKeys().hasOnly([
          'tenantId',
          'lastTemperatureC',
          'lastTemperatureAt',
          'lastMotorLoadAmps',
          'lastGearboxPhotoUrl',
          'updatedAt'
        ])
        && request.resource.data.lastTemperatureC is number
        && request.resource.data.lastTemperatureAt is string;
    }

    // â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•
    // USERS â€” profily uĹľivatelĹŻ
    // â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•
    match /users/{userId} {
      // KaĹľdĂ˝ pĹ™ihlĂˇĹˇenĂ˝ vidĂ­ uĹľivatele (pro zobrazenĂ­ jmen)
      allow read: if isAnyRole();

      // VlastnĂ­ profil mĹŻĹľe editovat kaĹľdĂ˝ (omezenĂˇ pole)
      // CizĂ­ profil jen SUPERADMIN/MAJITEL/VEDENI
      allow update: if isAuth() && (
        // VlastnĂ­ profil â€” nesmĂ­ mÄ›nit role
        isSafeOwnUserUpdate(userId)
        || isSafeManagedUserUpdate()
      ) && hasTimestamp();

      // VytvoĹ™enĂ­ jen SUPERADMIN
      allow create: if isSuperAdmin();

      // HARD DELETE â€” POUZE SUPERADMIN
      allow delete: if isSuperAdmin();
    }

    // ===============================================================
    // USER_SECRETS - pinHash pro prihlaseni. Pristup JEN pres Cloud
    // Functions (admin SDK obchazi pravidla). Klient nesmi cist ani psat.
    // ===============================================================
    match /user_secrets/{userId} {
      allow read, write: if false;
    }

    // ===============================================================
    // LOGIN_ATTEMPTS - pocitadlo pokusu / lockout. Jen Cloud Functions.
    // ===============================================================
    match /login_attempts/{attemptId} {
      allow read, write: if false;
    }

    // â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•
    // ASSETS â€” zaĹ™Ă­zenĂ­ / stroje
    // â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•
    match /assets/{assetId} {
      allow read: if hasPermission('asset.read');
      allow create: if hasPermission('asset.create') && hasTimestamp();
      allow update: if isAuth() && (
        hasPermission('asset.update')
        || (canWriteGearboxTemperature() && isGearboxTemperatureAssetUpdate())
        || (isOperator() && isSoftDelete())
      ) && hasTimestamp();
      allow delete: if hasPermission('asset.delete');

      match /pest_logs/{logId} {
        allow read: if hasPermission('asset.read');
        allow create: if hasPermission('asset.update');
        allow update: if false;
        allow delete: if hasPermission('asset.delete');
      }

      match /empty_logs/{logId} {
        allow read: if hasPermission('asset.read');
        allow create: if hasPermission('asset.update');
        allow update: if false;
        allow delete: if hasPermission('asset.delete');
      }
    }
    // TENANT ASSETS â€” v2 tenant-aware asset tree
    // â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•
    match /tenants/{tenantId}/assets/{assetId} {
      allow read: if hasPermission('asset.read')
        && getUserDoc().tenantId == tenantId;

      allow create: if hasPermission('asset.create')
        && request.resource.data.tenantId == tenantId
        && getUserDoc().tenantId == tenantId
        && hasTimestamp();

      allow update: if (
        hasPermission('asset.update')
        || (canWriteGearboxTemperature() && isGearboxTemperatureAssetUpdate())
        || (isOperator() && isSoftDelete())
      )
        && request.resource.data.tenantId == tenantId
        && resource.data.tenantId == tenantId
        && getUserDoc().tenantId == tenantId
        && hasTimestamp();

      allow delete: if hasPermission('asset.delete');
    }
    // STATS_AGGREGATES â€” agregovanĂˇ statistika
    // â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•
    match /stats_aggregates/{docId} {
      allow read: if isAnyRole();
      // ZĂˇpis jen Cloud Functions (Admin SDK) nebo SUPERADMIN
      allow write: if isSuperAdmin();
    }

    match /stats_aggregates/{docId}/{subCol}/{subDocId} {
      allow read: if isAnyRole();
      allow write: if isSuperAdmin();
    }

    // â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•
    // TASKS â€” Ăşkoly / work orders (Status Lock)
    // â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•
    match /tasks/{taskId} {
      allow read: if hasPermission('wo.read');
      allow create: if hasPermission('wo.create') && hasTimestamp();
      allow update: if isAuth() && hasTimestamp() && (
        hasPermission('wo.delete')
        || hasPermission('wo.update')
        || hasPermission('wo.close')
        || (hasPermission('wo.read') && isTaskStartOnlyUpdate())
      );
      allow delete: if hasPermission('wo.delete');
    }
    // REVISIONS â€” revize zaĹ™Ă­zenĂ­
    // â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•
    match /vacation_plans/{planId} {
      allow read: if isAnyRole();
      allow create: if (isManagement() || isTechnician()) && hasTimestamp();
      allow update: if (isManagement() || isTechnician()) && hasTimestamp();
      allow delete: if isSuperAdmin();
    }

    match /workLogs/{logId} {
      allow read: if hasPermission('wo.read') || hasPermission('report.read');
      allow create: if (
          hasPermission('wo.create')
          || hasPermission('wo.update')
          || (
            hasPermission('hvac.manage')
            && request.resource.data.workType is string
            && request.resource.data.workType.matches('.*VZT.*')
          )
        )
        && request.resource.data.createdAt is timestamp
        && (!('workOrderId' in request.resource.data) || request.resource.data.workOrderId is string)
        && request.resource.data.userName is string
        && request.resource.data.content is string;
      allow update: if hasPermission('wo.update')
        && hasTimestamp()
        && request.resource.data.userName is string
        && request.resource.data.content is string;
      allow delete: if hasPermission('wo.delete');
    }

    match /gearbox_temperature_logs/{logId} {
      allow read: if hasPermission('asset.read') || hasPermission('report.read');
      allow create: if canWriteGearboxTemperature()
        && request.resource.data.createdAt is timestamp
        && request.resource.data.measuredAt is timestamp
        && request.resource.data.gearboxId is string
        && request.resource.data.userName is string;
      allow update: if false;
      allow delete: if hasPermission('asset.delete');
    }

    match /datalogger_temperature_logs/{logId} {
      allow read: if hasPermission('datalogger.read')
        || hasPermission('datalogger.temperature.write')
        || hasPermission('datalogger.manage')
        || hasPermission('report.read');
      allow create: if (hasPermission('datalogger.temperature.write') || hasPermission('datalogger.manage'))
        && request.resource.data.createdAt is timestamp
        && request.resource.data.measuredAt is timestamp
        && request.resource.data.temperatureC is number
        && request.resource.data.dataloggerId is string
        && request.resource.data.dataloggerName is string
        && request.resource.data.userName is string;
      allow update: if false;
      allow delete: if hasPermission('datalogger.manage');
    }

    match /gearbox_installation_events/{eventId} {
      allow read: if hasPermission('asset.read') || hasPermission('report.read');
      allow create: if hasPermission('asset.update')
        && request.resource.data.createdAt is timestamp
        && request.resource.data.performedAt is timestamp
        && request.resource.data.gearboxId is string
        && request.resource.data.userName is string;
      allow update: if false;
      allow delete: if hasPermission('asset.delete');
    }

    match /revisions/{revisionId} {
      allow read: if hasPermission('asset.read') || hasPermission('report.read');
      allow create: if hasPermission('asset.update') && hasTimestamp();
      allow update: if hasPermission('asset.update') && hasTimestamp();
      allow delete: if hasPermission('asset.delete');
    }
    // INVENTORY â€” nĂˇhradnĂ­ dĂ­ly
    // â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•
    match /inventory/{itemId} {
      allow read: if canReadInventory() || hasPermission('report.read');
      allow create: if (hasPermission('inv.manage') || hasPermission('inv.restock')) && hasTimestamp();
      allow update: if canReadInventory() && hasTimestamp();
      allow delete: if hasPermission('inv.manage');
    }

    match /inventory_transactions/{txId} {
      allow read: if canReadInventory() || hasPermission('report.read');
      allow create: if canReadInventory()
        && request.resource.data.createdAt is timestamp;
      allow update: if false;
      allow delete: if hasPermission('inv.manage');
    }

    match /purchase_orders/{orderId} {
      allow read: if canReadInventory() || hasPermission('purchase.approve');
      allow create: if hasPermission('inv.order') && hasTimestamp();
      allow update: if (hasPermission('inv.order') || hasPermission('purchase.approve')) && hasTimestamp();
      allow delete: if hasPermission('inv.manage');
    }

    match /fleet/{vehicleId} {
      allow read: if hasPermission('fleet.read') || hasPermission('fleet.manage');
      allow create: if hasPermission('fleet.manage') && hasTimestamp();
      allow update: if (hasPermission('fleet.manage') || isUdrzba()) && hasTimestamp();
      allow delete: if hasPermission('fleet.manage') && isSuperAdmin();
    }

    match /waste/{wasteId} {
      allow read: if isAnyRole();
      allow create: if isManagement() && hasTimestamp();
      allow update: if (isManagement() || isTechnician()) && hasTimestamp();
      allow delete: if isSuperAdmin();
    }
    // TRUSTBOX â€” anonymnĂ­ schrĂˇnka (Dual-kolekce systĂ©m)
    // â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•
    //
    // ARCHITEKTURA:
    //   trustbox_ingress = "ÄŚernĂˇ dĂ­ra" (nikdo neÄŤte, jen zĂˇpis)
    //   trustbox_public  = "VeĹ™ejnĂˇ nĂˇstÄ›nka" (ÄŤte vedenĂ­)
    //
    // FLOW:
    //   1. UĹľivatel â†’ trustbox_ingress (create only)
    //   2. Synology mixer (Admin SDK) â†’ pĹ™esune, zamĂ­chĂˇ, smaĹľe timestamp
    //   3. VedenĂ­ ÄŤte â†’ trustbox_public
    //
    // SYNOLOGY MIXER: ZatĂ­m nepĹ™ipojen.
    //   AĹľ bude ready, nastavĂ­ se CRON na Synology s Admin SDK.
    //   Do tĂ© doby funguje FALLBACK pĹ™es trustbox_public pĹ™Ă­mo.
    //

    // INGRESS â€” "ÄŚernĂˇ dĂ­ra" (nikdo nesmĂ­ ÄŤĂ­st, jen vhodit lĂ­stek)
    match /trustbox_ingress/{docId} {
      allow create: if isAnyRole();              // Kdokoliv vhodĂ­ lĂ­stek
      allow read, update, delete: if false;      // Nikdo nevidĂ­ dovnitĹ™
    }

    // PUBLIC â€” "VeĹ™ejnĂˇ nĂˇstÄ›nka" (jen vedenĂ­ ÄŤte)
    match /trustbox_public/{docId} {
      allow read: if isManagement();             // VedenĂ­ + admin ÄŤte
      allow create: if false;                    // Jen Admin SDK (Synology) sem pĂ­Ĺˇe
      allow update: if isManagement() && hasTimestamp(); // OdpovÄ›di na zprĂˇvy
      allow delete: if isSuperAdmin();
    }

    // FALLBACK â€” dokud nenĂ­ Synology mixer, app pĂ­Ĺˇe pĹ™Ă­mo sem
    // Po napojenĂ­ Synology tuto kolekci zruĹˇĂ­me
    match /trustbox/{messageId} {
      allow read: if isManagement() || isMajitel();
      allow create: if isAnyRole();
      allow update: if (isManagement() || isMajitel()) && hasTimestamp();
      allow delete: if isSuperAdmin();
    }

    // â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•
    // AREAS â€” mĂ­stnosti / zĂłny
    // â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•
    match /prefilters/{logId} {
      allow read: if hasPermission('asset.read') || hasPermission('report.read');
      allow create: if (hasPermission('wo.create') || hasPermission('asset.update'))
        && request.resource.data.changedAt is timestamp
        && request.resource.data.assetId is string
        && request.resource.data.assetName is string
        && request.resource.data.createdAt is timestamp;
      allow update: if false;
      allow delete: if hasPermission('asset.delete');
    }

    match /areas/{areaId} {
      allow read: if isAnyRole();
      allow create: if isManagement() && hasTimestamp();
      allow update: if isManagement() && hasTimestamp();
      allow delete: if isSuperAdmin();
    }

    // â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•
    // AUDIT_LOGS â€” zĂˇznamy o akcĂ­ch (append-only)
    // â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•
    match /audit_logs/{logId} {
      // ÄŚtenĂ­ jen admin
      allow read: if isAdmin();

      // ZĂˇpis â€” kdokoliv pĹ™ihlĂˇĹˇenĂ˝ (hook zapisuje automaticky)
      allow create: if isAnyRole() && isClientAuditLogCreate();

      // NIKDO nesmĂ­ editovat ani mazat audit logy!
      allow update: if false;
      allow delete: if false;
    }

    // â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•
    // NOTIFICATIONS â€” notifikace
    // â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•
    match /notifications/{notifId} {
      // UĹľivatel vidĂ­ svĂ© notifikace
      allow read: if isAuth() && (
        resource.data.userId == request.auth.uid
        || isManagement()
      );

      allow create: if isAnyRole() && isValidNotificationCreate();

      // OznaÄŤit jako pĹ™eÄŤtenĂ©
      allow update: if isAuth() && (
        resource.data.userId == request.auth.uid
        || isManagement()
      );

      allow delete: if isSuperAdmin();
    }

    // â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•
    // SETTINGS â€” systĂ©movĂˇ konfigurace
    // â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•
    match /pushTokens/{tokenId} {
      allow read: if isAuth() && (
        resource.data.userId == request.auth.uid
        || isManagement()
      );

      allow create: if isAuth()
        && request.resource.data.userId == request.auth.uid
        && request.resource.data.token is string;

      allow update: if isAuth()
        && resource.data.userId == request.auth.uid
        && request.resource.data.userId == request.auth.uid;

      allow delete: if isAuth() && (
        resource.data.userId == request.auth.uid
        || isManagement()
      );
    }

    match /settings/{settingId} {
      allow read: if isAnyRole();

      // POUZE SUPERADMIN mÄ›nĂ­ systĂ©movĂ© nastavenĂ­
      allow create: if isSuperAdmin();
      allow update: if isSuperAdmin();
      allow delete: if isSuperAdmin();
    }

    match /shiftNotes/{noteId} {
      allow read: if isAnyRole();
      allow create: if isAnyRole()
        && request.resource.data.text is string
        && request.resource.data.authorId == request.auth.uid
        && request.resource.data.author is string
        && request.resource.data.priority in ['normal', 'important']
        && request.resource.data.shift in ['morning', 'afternoon']
        && request.resource.data.recipient is string
        && request.resource.data.createdAt is timestamp
        && hasTimestamp();
      allow update: if (isManagement() && hasTimestamp())
        || (
          isAnyRole()
          && hasTimestamp()
          && request.resource.data.diff(resource.data).changedKeys().hasOnly(['acknowledgedBy', 'acknowledgedByName', 'updatedAt'])
        );
      allow delete: if isManagement() || isSuperAdmin();
    }

    // â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•
    // LOUPĂRNA â€” sila, vĂ˝roba, plevy, stanice
    // â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•
    match /louparna_silos/{siloId} {
      allow read: if isAnyRole();
      allow create: if (isManagement() || isTechnician()) && hasTimestamp();
      allow update: if (isManagement() || isTechnician()) && hasTimestamp();
      allow delete: if isSuperAdmin();
    }

    match /louparna_production/{batchId} {
      allow read: if isAnyRole();
      allow create: if (isManagement() || isTechnician() || isOperator()) && hasTimestamp();
      allow update: if (isManagement() || isTechnician()) && hasTimestamp();
      allow delete: if isSuperAdmin();
    }

    match /louparna_waste/{wasteId} {
      allow read: if isAnyRole();
      allow create: if (isManagement() || isTechnician() || isOperator()) && hasTimestamp();
      allow update: if (isManagement() || isTechnician()) && hasTimestamp();
      allow delete: if isSuperAdmin();
    }

    match /louparna_machines/{machineId} {
      allow read: if isAnyRole();
      allow create: if (isManagement() || isTechnician()) && hasTimestamp();
      allow update: if (isManagement() || isTechnician()) && hasTimestamp();
      allow delete: if isSuperAdmin();
    }

    // â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•
    // ROLES â€” definice rolĂ­ (RBAC)
    // â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•
    match /counters/{counterId} {
      allow read: if isAnyRole();
      allow create: if (
        hasPermission('wo.create')
        || hasPermission('production.read')
        || hasPermission('production.manage')
      )
        && request.resource.data.keys().hasOnly(['value', 'updatedAt'])
        && request.resource.data.value == 1
        && hasTimestamp();
      allow update: if (
        hasPermission('wo.create')
        || hasPermission('production.read')
        || hasPermission('production.manage')
      )
        && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['value', 'updatedAt'])
        && request.resource.data.value == resource.data.value + 1
        && hasTimestamp();
      allow delete: if false;
    }

    match /roles/{roleId} {
      allow read: if request.auth != null;
      allow write: if hasPermission('admin.manage');
    }

    match /permissions/{permId} {
      allow read: if request.auth != null;
      allow write: if hasPermission('admin.manage');
    }

    match /inspections/{docId} {
      allow read: if hasPermission('asset.read') || hasPermission('weekly.modify') || hasPermission('report.read');
      allow create: if canWriteInspection()
        && request.resource.data.createdAt is timestamp;
      allow update: if canWriteInspection();
      allow delete: if hasPermission('asset.delete');
    }

    match /inspection_templates/{docId} {
      allow read: if hasPermission('asset.read') || hasPermission('weekly.modify');
      allow create: if canWriteInspection();
      allow update: if canWriteInspection();
      allow delete: if hasPermission('asset.delete');
    }

    match /inspection_logs/{docId} {
      allow read: if hasPermission('asset.read') || hasPermission('report.read');
      allow create: if canWriteInspection() || hasPermission('wo.create');
      allow update: if canWriteInspection();
      allow delete: if hasPermission('asset.delete');
    }

    match /inspection_runs/{docId} {
      allow read: if hasPermission('asset.read') || hasPermission('report.read');
      allow create: if canWriteInspection()
        && request.resource.data.status == 'draft'
        && request.resource.data.startedAt is timestamp
        && request.resource.data.items is list
        && hasTimestamp();
      allow update: if canWriteInspection()
        && hasTimestamp()
        && (
          resource.data.status == 'draft'
          || (resource.data.status == 'closed' && request.resource.data.status == 'draft')
        );
      allow delete: if isSuperAdmin();
    }

    // ENTITIES â€” univerzĂˇlnĂ­ entity (Matryoshka)
    // â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•
    match /inspection_run_logs/{docId} {
      allow read: if hasPermission('asset.read') || hasPermission('report.read');
      allow create: if canWriteInspection() || hasPermission('wo.create');
      allow update: if false;
      allow delete: if hasPermission('asset.delete');
    }

    match /entities/{entityId} {
      allow read: if hasPermission('fleet.read')
        || hasPermission('fleet.manage');
      allow create: if hasPermission('fleet.manage') && hasTimestamp();
      allow update: if hasPermission('fleet.manage') && hasTimestamp();
      allow delete: if hasPermission('admin.manage');
    }

    // â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•
    // BLUEPRINTS â€” Ĺˇablony pro entity typy
    // â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•
    match /blueprints/{blueprintId} {
      allow read: if request.auth != null;
      allow write: if hasPermission('admin.manage');
    }

    // â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•
    // ENTITY_LOGS â€” audit trail pro entity
    // â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•
    match /entity_logs/{logId} {
      allow read: if request.auth != null;
      allow create: if request.auth != null;
      // Logy se nesmĂ­ editovat ani mazat (audit-proof)
      allow update: if false;
      allow delete: if false;
    }

    // â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•
    // NOTICEBOARD â€” tĂ˝movĂˇ nĂˇstÄ›nka
    // â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•
    match /noticeboard/{msgId} {
      allow read: if isAnyRole();
      allow create: if isManagement();
      allow update: if isManagement();
      allow delete: if isSuperAdmin();
    }

    // â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•
    // USER_ENGAGEMENT â€” sledovĂˇnĂ­ zapojenĂ­
    // â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•
    match /user_engagement/{docId} {
      allow read: if isManagement();
      allow create: if isAnyRole();
      allow update: if false;
      allow delete: if isSuperAdmin();
    }

    // â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•
    // DASHBOARD_CONFIGS â€” uĹľivatelskĂˇ konfigurace dashboardu
    // â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•
    match /dashboard_configs/{userId} {
      allow read: if isAuth() && request.auth.uid == userId;
      allow write: if isAuth() && request.auth.uid == userId;
    }

    // â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•
    // DASHBOARD_DEFAULTS â€” vĂ˝chozĂ­ konfigurace per role
    // â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•
    match /dashboard_defaults/{role} {
      allow read: if isAnyRole();
      allow write: if hasPermission('admin.manage');
    }

    // â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•
    // TENANT_SETTINGS â€” multi-tenant module config
    // â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•
    match /tenant_settings/{tenantId} {
      allow read: if isAnyRole();
      allow write: if hasPermission('admin.manage');
    }

    // â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•
    // TENANT_ROLES â€” custom positions per tenant
    // â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•
    match /tenant_roles/{roleId} {
      allow read: if isAnyRole();
      allow create: if hasPermission('admin.manage');
      allow update: if hasPermission('admin.manage');
      allow delete: if hasPermission('admin.manage');
    }

    match /recurring_tasks/{taskId} {
      allow read: if hasPermission('wo.read') || hasPermission('schedule.manage');
      allow create: if hasPermission('schedule.manage') && hasTimestamp();
      allow update: if hasPermission('schedule.manage') && hasTimestamp();
      allow delete: if hasPermission('schedule.manage');
    }

    match /production_extrusion/{docId} {
      allow read: if hasPermission('production.read') || hasPermission('production.manage') || hasPermission('report.read');
      allow create: if hasPermission('production.manage') && hasTimestamp();
      allow update: if hasPermission('production.manage') && hasTimestamp();
      allow delete: if isSuperAdmin();
    }

    match /production_packaging/{docId} {
      allow read: if hasPermission('production.read') || hasPermission('production.manage') || hasPermission('report.read');
      allow create: if hasPermission('production.manage') && hasTimestamp();
      allow update: if hasPermission('production.manage') && hasTimestamp();
      allow delete: if isSuperAdmin();
    }

    match /production_materials/{docId} {
      allow read: if hasPermission('production.manage') || hasPermission('report.read');
      allow create: if hasPermission('production.manage') && hasTimestamp();
      allow update: if hasPermission('production.manage') && hasTimestamp();
      allow delete: if hasPermission('production.manage');
    }

    match /production_areas/{docId} {
      allow read: if hasPermission('production.manage') || hasPermission('report.read');
      allow create: if hasPermission('production.manage') && hasTimestamp();
      allow update: if hasPermission('production.manage') && hasTimestamp();
      allow delete: if hasPermission('production.manage');
    }

    match /production_extruders/{docId} {
      allow read: if hasPermission('production.manage') || hasPermission('report.read');
      allow create: if hasPermission('production.manage') && hasTimestamp();
      allow update: if hasPermission('production.manage') && hasTimestamp();
      allow delete: if hasPermission('production.manage');
    }

    match /production_machine_recipes/{docId} {
      allow read: if hasPermission('production.read') || hasPermission('production.manage') || hasPermission('report.read');
      allow create: if hasPermission('production.manage') && hasTimestamp();
      allow update: if hasPermission('production.manage') && hasTimestamp();
      allow delete: if hasPermission('production.manage');
    }

    match /materials/{docId} {
      allow read: if hasPermission('production.read') || hasPermission('production.manage') || hasPermission('report.read');
      allow create: if hasPermission('production.manage') && hasTimestamp();
      allow update: if hasPermission('production.manage') && hasTimestamp();
      allow delete: if hasPermission('production.manage');
    }

    match /products/{docId} {
      allow read: if hasPermission('production.read') || hasPermission('production.manage') || hasPermission('report.read');
      allow create: if hasPermission('production.manage') && hasTimestamp();
      allow update: if hasPermission('production.manage') && hasTimestamp();
      allow delete: if hasPermission('production.manage');
    }

    match /warehouse_receipts/{docId} {
      allow read: if hasPermission('warehouse.view') || hasPermission('warehouse.manage');
      allow create: if hasPermission('warehouse.manage') && hasTimestamp();
      allow update: if hasPermission('warehouse.manage') && hasTimestamp();
      allow delete: if isSuperAdmin();
    }

    match /warehouse_stock/{docId} {
      allow read: if hasPermission('warehouse.view') || hasPermission('warehouse.manage');
      allow create: if hasPermission('warehouse.manage') && hasTimestamp();
      allow update: if hasPermission('warehouse.manage') && hasTimestamp();
      allow delete: if isSuperAdmin();
    }

    match /warehouse_shipments/{docId} {
      allow read: if hasPermission('warehouse.view') || hasPermission('warehouse.manage');
      allow create: if hasPermission('warehouse.manage') && hasTimestamp();
      allow update: if hasPermission('warehouse.manage') && hasTimestamp();
      allow delete: if isSuperAdmin();
    }

    match /shift_plans/{docId} {
      allow read: if hasPermission('shifts.view') || hasPermission('shifts.manage');
      allow create: if hasPermission('shifts.manage') && hasTimestamp();
      allow update: if hasPermission('shifts.manage') && hasTimestamp();
      allow delete: if isSuperAdmin();
    }

    match /user_notes/{docId} {
      allow read: if isAuth() && resource.data.userId == request.auth.uid;
      allow create: if isAuth() && request.resource.data.userId == request.auth.uid;
      allow update: if isAuth() && resource.data.userId == request.auth.uid;
      allow delete: if isAuth() && resource.data.userId == request.auth.uid;
    }

    // â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•
    // CATCH-ALL â€” deny everything else
    // â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•
    match /{document=**} {
      allow read, write: if false;
    }
  }
}



