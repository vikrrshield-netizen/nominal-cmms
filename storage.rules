// storage.rules
// NOMINAL CMMS — Firebase Storage Rules

rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {
    
    // Helper functions
    function isSignedIn() {
      return request.auth != null;
    }
    
    function isAdmin() {
      return request.auth.token.role in ['SUPERADMIN', 'VEDENI'];
    }

    function hasTokenPermission(permission) {
      return isSignedIn()
        && request.auth.token.permissions != null
        && request.auth.token.permissions.hasAny([permission]);
    }

    function canReadProductionDocs() {
      return hasTokenPermission('production.read')
        || hasTokenPermission('production.manage')
        || hasTokenPermission('report.read')
        || request.auth.token.role in ['MAJITEL', 'VEDENI', 'SUPERADMIN', 'UDRZBA', 'VYROBA', 'SKLADNIK', 'OPERATOR'];
    }

    function canWriteProductionDocs() {
      return hasTokenPermission('production.manage')
        || request.auth.token.role in ['SUPERADMIN', 'VEDENI', 'UDRZBA', 'VYROBA'];
    }

    function isSafeImageUpload(maxSizeBytes) {
      return request.resource != null
        && request.resource.size <= maxSizeBytes
        && request.resource.contentType.matches('image/.*');
    }

    // Jen limit velikosti (bez omezení typu — revize můžou být PDF certifikáty).
    function isUnderSize(maxSizeBytes) {
      return request.resource != null && request.resource.size <= maxSizeBytes;
    }

    // Revision documents (obrázky i PDF) — limit 20 MB proti abuse úložiště.
    match /revisions/{revisionId}/{allPaths=**} {
      allow read: if isSignedIn();
      allow write: if isAdmin() && isUnderSize(20 * 1024 * 1024);
    }

    // Asset images — limit 20 MB.
    match /assets/{assetId}/{allPaths=**} {
      allow read: if isSignedIn();
      allow write: if isSignedIn()
        && request.auth.token.role in ['SUPERADMIN', 'VEDENI', 'UDRZBA']
        && isUnderSize(20 * 1024 * 1024);
    }
    
    // User avatars
    match /users/{userId}/avatar {
      allow read: if isSignedIn();
      allow write: if isSignedIn() && request.auth.uid == userId;
    }
    
    // Fault report photos
    match /fault_photos/{allPaths=**} {
      allow read: if isSignedIn();
      allow create, update: if isSignedIn() && isSafeImageUpload(10 * 1024 * 1024);
      allow delete: if isSignedIn() && request.auth.token.role in ['SUPERADMIN', 'VEDENI', 'UDRZBA'];
    }

    // Gearbox temperature / camera checks
    match /gearbox_checks/{gearboxId}/{allPaths=**} {
      allow read: if isSignedIn();
      allow create, update: if isSignedIn() && isSafeImageUpload(10 * 1024 * 1024);
      allow delete: if isSignedIn() && request.auth.token.role in ['SUPERADMIN', 'VEDENI', 'UDRZBA'];
    }

    // Production master data documents: materials/products card attachments
    match /materials/{materialId}/docs/{allPaths=**} {
      allow read: if canReadProductionDocs();
      allow write: if canWriteProductionDocs();
    }

    match /products/{productId}/docs/{allPaths=**} {
      allow read: if canReadProductionDocs();
      allow write: if canWriteProductionDocs();
    }

    // Temporary uploads
    match /temp/{userId}/{allPaths=**} {
      allow read, write: if isSignedIn() && request.auth.uid == userId;
    }

    // Facility floor plans (půdorysy areálu) — CHRÁNĚNÉ: čtení i zápis jen vedení/údržba.
    match /facility_plans/{allPaths=**} {
      allow read: if isSignedIn() && request.auth.token.role in ['SUPERADMIN', 'VEDENI', 'UDRZBA'];
      allow create, update: if isSignedIn()
        && isSafeImageUpload(10 * 1024 * 1024)
        && request.auth.token.role in ['SUPERADMIN', 'VEDENI', 'UDRZBA'];
      allow delete: if isSignedIn() && request.auth.token.role in ['SUPERADMIN', 'VEDENI', 'UDRZBA'];
    }

    // Deny everything else
    match /{allPaths=**} {
      allow read, write: if false;
    }
  }
}
